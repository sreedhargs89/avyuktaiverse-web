# ── AvyuktAIverse® — environment template ──────────────
# Copy to .env.local and fill in real values.
# .env.local is gitignored.

# Public site URL (used by metadataBase, OG images, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form — Resend (https://resend.com)
# Leave empty in dev to log submissions to the console instead of sending.
RESEND_API_KEY=

# Inbox that receives contact-form submissions
CONTACT_TO_EMAIL=contact@avyuktaiverse.com

# Verified Resend "From" address (until a domain is verified, keep the default)
CONTACT_FROM_EMAIL="AvyuktAIverse Website <onboarding@resend.dev>"
